{% extends "base.html.j2" %}
{% block content %}
<article class="p-container p-sections p-project">
<nav class="p-back"><a href="/projects/">&larr; {{ t("projects.all") }}</a></nav>
<header class="p-project-head">
<h1>{{ page.title }}</h1>
{% set summary = page.get('summary') %}
{% if summary %}<p class="p-lead">{{ summary }}</p>{% endif %}
{% set tech = page.get('tech') or [] %}
{% if tech %}<ul class="p-chips p-chips-sm">{% for t in tech %}<li>{{ t }}</li>{% endfor %}</ul>{% endif %}
<div class="p-hero-actions">
{% set live = page.get('live_url') %}
{% if live %}<a class="p-btn p-btn-primary" href="{{ live }}" target="_blank" rel="noopener">{{ t("project.live") }}</a>{% endif %}
{% set repo = page.get('repo') %}
{% if repo %}<a class="p-btn" href="{{ repo }}" target="_blank" rel="noopener">{{ t("project.source") }}</a>{% endif %}
</div>
</header>
<div class="p-prose">{{ content_html }}</div>
</article>
{% endblock %}
