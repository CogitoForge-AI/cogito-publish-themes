{% extends "base.html.j2" %}
{% block content %}
<section class="container list">
{% if page.title %}<header><h1 class="title"><a class="title-link" href="{{ page.url }}">{{ page.title }}</a></h1></header>{% endif %}
{% if content_html %}{{ content_html }}{% endif %}
{% set items = page.get('items') %}
{% if items is not none %}
{# Collection index (blog preset): a paginated slice of posts. #}
<ul>
{% for post in items %}
<li>
{% if post.date %}<span class="date">{{ post.date }}</span>{% endif %}
<a class="title" href="{{ post.url }}">{{ post.title }}</a>
</li>
{% endfor %}
</ul>
{% set pg = page.get('pagination') %}
{% if pg and pg.total > 1 %}
{# coder's .pagination lays out compact tokens (~2.2rem each); render newer/older
   arrows around the current page number to match. #}
<ul class="pagination">
{% if pg.prev %}<li><a href="{{ pg.prev }}" aria-label="{{ t('pagination.newer') }}">&laquo;</a></li>{% endif %}
<li>{{ pg.current }}</li>
{% if pg.next %}<li><a href="{{ pg.next }}" aria-label="{{ t('pagination.older') }}">&raquo;</a></li>{% endif %}
</ul>
{% endif %}
{% else %}
{# Standalone use (no collection): list pages grouped by section from the nav menu. #}
<ul>
{% for sec in menu %}{% if sec.section %}{% for item in sec['items'] %}
<li><a class="title" href="{{ item.url }}">{{ item.title }}</a></li>
{% endfor %}{% endif %}{% endfor %}
</ul>
{% endif %}
</section>
{% endblock %}
