{% extends "base.html.j2" %}
{% block content %}
<section class="container taxonomy">
<header><h1 class="title">{{ page.title }}</h1></header>
<p>{{ t("term.tagged", count=page.count) }}</p>
<ul>
{% for m in page.members %}<li><span class="taxonomy-element"><a href="{{ m.url }}">{{ m.title }}</a></span></li>{% endfor %}
</ul>
</section>
{% endblock %}
