{% extends "base.html.j2" %}
{% block content %}
<section class="container taxonomy">
<header><h1 class="title">{{ page.title }}</h1></header>
<ul>
{% for tg in page.terms %}<li><span class="taxonomy-element"><a href="{{ tg.url }}">{{ tg.term }}</a> <sup>{{ tg.count }}</sup></span></li>{% endfor %}
</ul>
</section>
{% endblock %}
