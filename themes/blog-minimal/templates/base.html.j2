{#
  Base layout for the blog-minimal theme (ported from hugo-coder).

  Class names mirror coder so its compiled stylesheet applies unchanged. The
  body `colorscheme-*` class drives light/dark; theme.js refines it from the
  visitor's saved preference. `preload-transitions` suppresses the first-paint
  transition flash and is removed once loaded.
#}<!doctype html>
<html lang="{{ lang or 'en' }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if page.title %}{{ page.title }} &middot; {% endif %}{{ site.title }}</title>
{% set page_description = page.get('description') %}
{% if page_description %}<meta name="description" content="{{ page_description }}">{% endif %}
<link rel="stylesheet" href="/assets/style.css">
{% if site.highlight_css %}<style>{{ site.highlight_css }}</style>{% endif %}
{% for tr in translations %}<link rel="alternate" hreflang="{{ tr.lang }}" href="{{ tr.url }}">{% endfor %}
</head>
<body class="preload-transitions colorscheme-{{ theme.default_theme if theme.default_theme in ('light', 'dark') else 'auto' }}">
<main class="wrapper">
<nav class="navigation">
<section class="container">
<a class="navigation-title" href="/">{{ site.title }}</a>
<ul class="navigation-list">
<li class="navigation-item"><a class="navigation-link" href="/">{{ t("nav.home") }}</a></li>
<li class="navigation-item"><a class="navigation-link" href="/tags/">{{ t("nav.tags") }}</a></li>
{% for tr in translations %}<li class="navigation-item"><a class="navigation-link lang-link" hreflang="{{ tr.lang }}" href="{{ tr.url }}">{{ tr.lang|upper }}</a></li>{% endfor %}
</ul>
</section>
</nav>
<div class="content">
{% block content %}{% endblock %}
</div>
<footer class="footer">
<section class="container">
&copy; {{ site.title }} &middot; {{ t("footer.powered_by") }} <a href="https://github.com/magiskboy/pyssg" target="_blank" rel="noopener">pyssg</a>, theme from <a href="https://github.com/luizdepra/hugo-coder/" target="_blank" rel="noopener">Coder</a>.
</section>
</footer>
</main>
{% if theme.show_theme_toggle %}
<div class="float-container">
<a id="dark-mode-toggle" class="colorscheme-toggle" role="button" tabindex="0" aria-label="{{ t('theme.toggle') }}" title="{{ t('theme.toggle') }}">
<i aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 3a9 9 0 0 0 0 18z" fill="currentColor" stroke="none"></path></svg></i>
</a>
</div>
{% endif %}
{% if '<pre class="mermaid"' in content_html %}
<script type="module">
import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
mermaid.initialize({ startOnLoad: true });
</script>
{% endif %}
<script src="/assets/js/theme.js" data-theme-toggle="{{ 'true' if theme.show_theme_toggle else 'false' }}"></script>
</body>
</html>
