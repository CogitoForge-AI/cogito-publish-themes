{#
  Base layout for the docs-technical theme.

  Layout follows google/docsy (https://github.com/google/docsy): a top navbar,
  a left navigation sidebar, the main content, and a right "on this page" TOC.
  The CSS is hand-written (no Bootstrap), but class names mirror docsy's
  (`td-navbar`, `td-sidebar`, `td-content`, `td-sidebar-toc`) for familiarity.
  Light/dark is driven by `data-theme` on <html>; the accent color is a runtime
  option fed into the `--td-accent` custom property.
#}<!doctype html>
<html lang="{{ lang or 'en' }}"{% if theme.default_theme in ('light', 'dark') %} data-theme="{{ theme.default_theme }}"{% endif %}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if page.title %}{{ page.title }} | {% endif %}{{ site.title }}</title>
{% set page_description = page.get('description') %}
{% if page_description %}<meta name="description" content="{{ page_description }}">{% endif %}
<link rel="stylesheet" href="/assets/style.css">
<style>:root{--td-accent: {{ theme.accent }};}</style>
{% if site.highlight_css %}<style>{{ site.highlight_css }}</style>{% endif %}
{% for tr in translations %}<link rel="alternate" hreflang="{{ tr.lang }}" href="{{ tr.url }}">{% endfor %}
<script>
// Resolve the color scheme before first paint to avoid a flash.
(function () {
  var pref = localStorage.getItem("pref-theme");
  var dflt = {{ theme.default_theme | tojson }};
  var el = document.documentElement;
  if (pref === "dark" || pref === "light") { el.dataset.theme = pref; }
  else if (dflt === "dark" || dflt === "light") { el.dataset.theme = dflt; }
  else { el.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"; }
})();
</script>
</head>
<body>
<header class="td-navbar">
<div class="td-navbar-inner">
<button class="td-sidebar-toggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
<a class="td-brand" href="/">{{ site.title }}</a>
<nav class="td-navbar-nav">
<a href="/tags/">{{ t("nav.tags") }}</a>
<a href="/categories/">{{ t("nav.categories") }}</a>
{% for tr in translations %}<a class="lang-link" hreflang="{{ tr.lang }}" href="{{ tr.url }}">{{ tr.lang|upper }}</a>{% endfor %}
<button id="theme-toggle" class="td-theme-toggle" aria-label="Toggle theme" title="Toggle theme">
<svg class="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
<svg class="sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
</button>
</nav>
</div>
</header>
<div class="td-main">
<aside class="td-sidebar" aria-label="Main navigation">
<div class="td-sidebar-inner">
{% if theme.sidebar_title %}<a class="td-sidebar-title" href="/">{{ theme.sidebar_title }}</a>{% endif %}
{% for sec in menu %}
<div class="td-sidebar-group">
{% if sec.section %}<p class="td-sidebar-heading">{{ sec.section }}</p>{% endif %}
<ul>{% for item in sec['items'] %}<li><a href="{{ item.url }}"{% if item.url == page.url %} class="active"{% endif %}>{{ item.title }}</a></li>{% endfor %}</ul>
</div>
{% endfor %}
</div>
</aside>
<main class="td-content" role="main">
{% block content %}{% endblock %}
</main>
<aside class="td-sidebar-toc" aria-label="On this page">
{% block toc %}{% endblock %}
</aside>
</div>
{% if '<pre class="mermaid"' in content_html %}
<script type="module">
import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
mermaid.initialize({ startOnLoad: true });
</script>
{% endif %}
<script src="/assets/js/theme.js"></script>
</body>
</html>
