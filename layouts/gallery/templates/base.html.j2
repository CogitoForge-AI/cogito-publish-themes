{#
  Base layout for the Cogito Publish Themes gallery (themes.gohugo.io-style showcase).

  A slim top bar, a centered content column, and a footer. Light/dark is driven
  by `data-theme` on <html>; an inline no-flash script resolves the scheme before
  first paint and the toggle persists a choice in localStorage. The accent color
  is a runtime theme option fed into the `--accent` custom property.
#}<!doctype html>
<html lang="{{ lang or 'en' }}"{% if theme.default_theme in ('light', 'dark') %} data-theme="{{ theme.default_theme }}"{% endif %}>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if page.title %}{{ page.title }} &middot; {% endif %}{{ site.title }}</title>
{% set page_description = page.get('description') or page.get('excerpt') %}
{% if page_description %}<meta name="description" content="{{ page_description }}">{% endif %}
<link rel="stylesheet" href="/assets/style.css">
<style>:root{--accent: {{ theme.accent }};}</style>
<script>
// Resolve the color scheme before first paint to avoid a flash.
(function () {
  var pref = localStorage.getItem("pref-theme");
  var dflt = {{ theme.default_theme | tojson }};
  var el = document.documentElement;
  if (pref === "dark" || pref === "light") { el.dataset.theme = pref; }
  else if (dflt === "dark" || dflt === "light") { el.dataset.theme = dflt; }
  else { el.dataset.theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"; }
})();
</script>
</head>
<body>
<header class="g-navbar">
<div class="g-container g-navbar-inner">
<a class="g-brand" href="/">{{ site.title }}</a>
<nav class="g-nav">
<a href="/">{{ t("nav.themes") }}</a>
<a href="https://github.com/CogitoForge-AI/cogito-publish" target="_blank" rel="noopener">{{ t("nav.pyssg") }}</a>
<button id="theme-toggle" class="g-theme-toggle" aria-label="{{ t('theme.toggle') }}" title="{{ t('theme.toggle') }}">
<svg class="moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
<svg class="sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
</button>
</nav>
</div>
</header>
<main class="g-main">
{% block content %}{% endblock %}
</main>
<footer class="g-footer">
<div class="g-container">
{{ t("footer.tagline") }} <a href="https://github.com/CogitoForge-AI/cogito-publish" target="_blank" rel="noopener">Cogito Publish</a>.
</div>
</footer>
<script>
// Theme toggle: flip data-theme and remember the choice.
(function () {
  var btn = document.getElementById("theme-toggle");
  if (!btn) return;
  btn.addEventListener("click", function () {
    var el = document.documentElement;
    var next = el.dataset.theme === "dark" ? "light" : "dark";
    el.dataset.theme = next;
    localStorage.setItem("pref-theme", next);
  });
})();
</script>
</body>
</html>
